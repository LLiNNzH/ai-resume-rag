# OpenAI 兼容接口（支持 OpenAI / Qwen / GLM 等，前提是兼容 OpenAI Chat Completions）
PROVIDER=openai
BASE_URL=https://api.openai.com/v1
API_KEY=

# 模型
MODEL_ID=gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# 向量化与分块（可选）
# OpenAI embedding model（OpenAI Embeddings API）
# 例如：text-embedding-3-small 或 text-embedding-3-large
EMBED_MODEL=text-embedding-3-small
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=8
